<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="416.0" prefWidth="500.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20px; -fx-border-radius: 8px;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.personal.studytracker.window.scheduleManage">
    <children>
        <Label layoutX="34.0" layoutY="43.0" style="-fx-font-weight: bold;" text="Add Schedule">
            <font>
                <Font name="Inter Semi Bold" size="30.0" />
            </font></Label>
        <Label layoutX="34.0" layoutY="79.0" text="Customize your course and set its schedule." textFill="#666666">
            <font>
                <Font name="Inter Regular" size="12.0" />
            </font>
        </Label>

        <VBox layoutX="34.0" layoutY="117.0" prefHeight="315.0" prefWidth="435.0" spacing="15.0">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Course Name">
                            <font>
                                <Font name="Inter Regular" size="13.0" />
                            </font></Label>
                    </children>
                </VBox>
            <ComboBox prefHeight="33.0" prefWidth="494.0" />

                <VBox spacing="5.0">
                    <children>
                        <Label text="Schedule Day">
                            <font>
                                <Font name="Inter Regular" size="13.0" />
                            </font></Label>
                    </children>
                </VBox>
            <ComboBox prefHeight="35.0" prefWidth="480.0" />
            <HBox maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="61.0" prefWidth="235.0" spacing="20.0">
               <children>
                  <VBox alignment="CENTER_LEFT" prefHeight="200.0" prefWidth="100.0">
                     <children>
                        <Label text="Start Time">
                           <font>
                              <Font name="Inter Regular" size="13.0" />
                           </font>
                        </Label>
                        <ComboBox prefHeight="35.0" prefWidth="150.0" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" prefHeight="200.0" prefWidth="100.0">
                     <children>
                        <Label text="End Time">
                           <font>
                              <Font name="Inter Regular" size="13.0" />
                           </font>
                        </Label>
                        <ComboBox prefHeight="35.0" prefWidth="150.0" />
                     </children>
                  </VBox>
               </children>
            </HBox>
      
              <HBox alignment="CENTER_RIGHT" prefHeight="62.0" prefWidth="435.0" spacing="20.0">
                  <children>
                      <Button fx:id="saveButton" mnemonicParsing="false" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #a16262;" text="Save" textFill="WHITE">
                          <font>
                              <Font name="Inter Regular" size="14.0" />
                          </font>
                  </Button>
                      <Button fx:id="cancelButton" contentDisplay="CENTER" mnemonicParsing="false" onAction="#cancelButton" prefHeight="40.0" prefWidth="120.0" text="Cancel">
                          <font>
                              <Font name="Inter Regular" size="14.0" />
                          </font>
                  </Button>
                  </children>
              </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
